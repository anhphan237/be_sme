<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sme.be_sme.modules.document.infrastructure.mapper.DocumentVersionMapper">

  <select id="selectMaxVersionNoByDocumentId" resultType="java.lang.Integer">
    select max(version_no)
    from document_versions
    where document_id = #{documentId,jdbcType=VARCHAR}
  </select>
</mapper>
