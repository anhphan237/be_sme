	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"pm.test(\"Status code is 200\", function () {",
					"    pm.response.to.have.status(200);",
					"});",
					"",
					"pm.test(\"Response is JSON\", function () {",
					"    pm.response.to.be.json;",
					"});",
					"",
					"pm.test(\"Response has success property\", function () {",
					"    var jsonData = pm.response.json();",
					"    pm.expect(jsonData).to.have.property('success');",
					"});",
					"",
					"// Store task instance ID for chaining tests",
					"pm.test(\"Store task data\", function () {",
					"    var jsonData = pm.response.json();",
					"    if (jsonData.success && jsonData.payload) {",
					"        pm.collectionVariables.set(\"task_title\", jsonData.payload.title);",
					"        pm.collectionVariables.set(\"task_status\", jsonData.payload.status);",
					"    }",
					"});"
				]
			}
		}
	],
