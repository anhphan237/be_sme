	"item": [
		{
			"name": "Get Task Detail",
			"item": [
				{
					"name": "1. Get Task Detail (Basic - All Includes)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"operationType\": \"com.sme.onboarding.task.detail\",\n    \"requestId\": \"{{$randomUUID}}\",\n    \"payload\": {\n        \"taskId\": \"{{task_instance_id}}\",\n        \"includeComments\": true,\n        \"includeAttachments\": true,\n        \"includeActivityLogs\": true\n    }\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/v1/gateway",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"gateway"
							]
						},
						"description": "Get full task detail including comments, attachments, and activity logs"
					},
					"response": []
				},
